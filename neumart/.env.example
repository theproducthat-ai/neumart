# ─────────────────────────────────────────────────────────────────────────────
# Nuemart — Environment Variables
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Convex ────────────────────────────────────────────────────────────────────
# Found in: Convex dashboard → Settings → URL & Deploy Key
NEXT_PUBLIC_CONVEX_URL=https://<your-convex-deployment>.convex.cloud

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Found in: Clerk dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# ── App URL ───────────────────────────────────────────────────────────────────
# Base URL of the deployed app (used for absolute links, webhooks, etc.)
# In development: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# FUTURE — Razorpay Payment Gateway (not yet integrated)
# Add these when wiring up Razorpay in the next phase.
# ─────────────────────────────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=rzp_test_
# RAZORPAY_KEY_SECRET=
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_
# RAZORPAY_WEBHOOK_SECRET=
